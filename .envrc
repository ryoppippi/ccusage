if has nix; then
  watch_file pnpm-lock.yaml
  watch_file pnpm-workspace.yaml
  # Reload the dev shell when any flake evaluation input changes. `use flake`
  # only tracks flake.nix/flake.lock, so imported modules under nix/ (and the
  # rust toolchain pin they read) would otherwise go stale and keep a baked-in
  # dev shell — e.g. an outdated treefmt wrapper in the installed git hooks.
  watch_file flake.nix
  watch_file flake.lock
  watch_file dev/flake.nix
  watch_file dev/flake.lock
  watch_file rust-toolchain.toml
  watch_dir nix
  use flake ./dev
fi
