# Recipes for the VitePress documentation site. Run from the repo root as
# `just docs::<recipe>`, or from this directory as `just <recipe>`.

[private]
default:
    @just --list

# Build the site (delegated; wrangler.jsonc runs `pnpm run build`, which also
# copies the generated schema into public/ before VitePress)
build:
    pnpm run build

# Start the dev server (the pnpm script copies the schema into public/ first)
dev:
    pnpm run dev

# Type-check the site (tsgo comes from the Nix dev shell, so call it directly)
typecheck:
    tsgo --noEmit

# Preview the production build locally
preview:
    pnpm exec vitepress preview

# Deploy to Cloudflare
deploy:
    pnpm exec wrangler deploy
