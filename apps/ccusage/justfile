# Recipes for the published `ccusage` npm package. Run from the repo root as
# `just ccusage::<recipe>`, or from this directory as `just <recipe>`.

[private]
default:
    @just --list

# Build the package bundle and verify native binary glue.
build: build-package

build-package:
    pnpm exec tsdown
    just ensure-native-binary

prepack:
    just build-package
    pnpm exec clean-pkg-json

build-rust:
    cargo build --manifest-path ../../rust/Cargo.toml --release --bin ccusage

ensure-native-binary:
    scripts/ensure-native-binary.nu

generate-schema:
    cargo run --quiet --manifest-path ../../rust/Cargo.toml --bin generate-config-schema -- config-schema.json
    oxfmt --write config-schema.json
    cp config-schema.json ../../docs/public/config-schema.json

start *args:
    cargo run --manifest-path ../../rust/Cargo.toml --bin ccusage -- {{args}}

test-statusline:
    just test-statusline-file test/statusline-test.json

test-statusline-all:
    @echo 'Testing Sonnet 4:'
    just test-statusline-sonnet4
    @echo 'Testing Opus 4.1:'
    just test-statusline-opus4
    @echo 'Testing Sonnet 4.1:'
    just test-statusline-sonnet41

test-statusline-opus4:
    just test-statusline-file test/statusline-test-opus4.json --offline

test-statusline-sonnet4:
    just test-statusline-file test/statusline-test-sonnet4.json --offline

test-statusline-sonnet41:
    just test-statusline-file test/statusline-test-sonnet41.json --offline

test-statusline-file file *args:
    cargo run --manifest-path ../../rust/Cargo.toml --bin ccusage -- statusline {{args}} < {{file}}

# Type-check the package (tsgo comes from the Nix dev shell, so call it directly)
typecheck:
    tsgo --noEmit
