{
	"name": "ccusage",
	"version": "20.0.11",
	"description": "Analyze coding (agent) CLI token usage and costs from local data",
	"homepage": "https://github.com/ccusage/ccusage#readme",
	"bugs": {
		"url": "https://github.com/ccusage/ccusage/issues"
	},
	"license": "MIT",
	"author": "ryoppippi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ccusage/ccusage.git",
		"directory": "apps/ccusage"
	},
	"funding": "https://github.com/sponsors/ryoppippi",
	"bin": {
		"ccusage": "./src/cli.ts"
	},
	"files": [
		"config-schema.json",
		"dist/**/*.js"
	],
	"type": "module",
	"publishConfig": {
		"bin": {
			"ccusage": "./dist/cli.js"
		}
	},
	"scripts": {
		"bench": "just bench",
		"build": "tsdown && scripts/ensure-native-binary.nu",
		"build:rust": "just build-rust",
		"ensure:native-binary": "just ensure-native-binary",
		"generate:schema": "just generate-schema",
		"prepack": "pnpm run build && clean-pkg-json",
		"start": "just start",
		"test:statusline": "just test-statusline",
		"test:statusline:all": "just test-statusline-all",
		"test:statusline:opus4": "just test-statusline-opus4",
		"test:statusline:sonnet4": "just test-statusline-sonnet4",
		"test:statusline:sonnet41": "just test-statusline-sonnet41"
	},
	"devDependencies": {
		"@types/bun": "catalog:types",
		"clean-pkg-json": "catalog:release",
		"fs-fixture": "catalog:testing",
		"mitata": "catalog:testing",
		"publint": "catalog:lint",
		"tsdown": "catalog:build",
		"vitest": "catalog:testing"
	},
	"optionalDependencies": {
		"@ccusage/ccusage-darwin-arm64": "workspace:*",
		"@ccusage/ccusage-darwin-x64": "workspace:*",
		"@ccusage/ccusage-linux-arm64": "workspace:*",
		"@ccusage/ccusage-linux-x64": "workspace:*",
		"@ccusage/ccusage-win32-arm64": "workspace:*",
		"@ccusage/ccusage-win32-x64": "workspace:*"
	}
}
