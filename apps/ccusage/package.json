{
	"name": "ccusage",
	"version": "20.0.11",
	"description": "Analyze coding (agent) CLI token usage and costs from local data",
	"homepage": "https://github.com/ccusage/ccusage#readme",
	"bugs": {
		"url": "https://github.com/ccusage/ccusage/issues"
	},
	"license": "MIT",
	"author": "ryoppippi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ccusage/ccusage.git",
		"directory": "apps/ccusage"
	},
	"funding": "https://github.com/sponsors/ryoppippi",
	"bin": {
		"ccusage": "./src/cli.ts"
	},
	"files": [
		"config-schema.json",
		"dist/**/*.js"
	],
	"type": "module",
	"publishConfig": {
		"bin": {
			"ccusage": "./dist/cli.js"
		}
	},
	"scripts": {
		"build": "tsdown && scripts/ensure-native-binary.nu",
		"prepack": "pnpm run build && clean-pkg-json"
	},
	"devDependencies": {
		"@types/node": "catalog:types",
		"clean-pkg-json": "catalog:release",
		"publint": "catalog:lint",
		"tsdown": "catalog:build"
	},
	"optionalDependencies": {
		"@ccusage/ccusage-darwin-arm64": "workspace:*",
		"@ccusage/ccusage-darwin-x64": "workspace:*",
		"@ccusage/ccusage-linux-arm64": "workspace:*",
		"@ccusage/ccusage-linux-x64": "workspace:*",
		"@ccusage/ccusage-win32-arm64": "workspace:*",
		"@ccusage/ccusage-win32-x64": "workspace:*"
	}
}
