---
source: crates/ccusage/src/cli.rs
expression: cases
---
[
  {
    "args": [
      "ccusage",
      "--daily"
    ],
    "error": "Report flags like --daily are not supported. Use \"ccusage daily\" instead."
  },
  {
    "args": [
      "ccusage",
      "daily",
      "--agent",
      "codex"
    ],
    "error": "Agent filters like --agent are not supported. Use \"ccusage <agent> <report>\", for example \"ccusage codex daily\"."
  },
  {
    "args": [
      "ccusage",
      "codex",
      "blocks"
    ],
    "error": "The \"blocks\" report is only available for Claude Code usage.\nUse \"ccusage codex daily\" for Codex usage reports."
  },
  {
    "args": [
      "ccusage",
      "--mode",
      "bad"
    ],
    "error": "Invalid cost mode 'bad'"
  },
  {
    "args": [
      "ccusage",
      "blocks",
      "--session-length",
      "abc"
    ],
    "error": "Invalid value for --session-length"
  },
  {
    "args": [
      "ccusage",
      "statusline",
      "--visual-burn-rate",
      "loud"
    ],
    "error": "Invalid visual burn rate 'loud'"
  },
  {
    "args": [
      "ccusage",
      "pi",
      "weekly"
    ],
    "error": "The \"weekly\" report is not available for pi-agent usage.\nUse \"ccusage pi daily\" for pi-agent usage reports."
  }
]
